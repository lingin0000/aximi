{
  "expo": {
    "name": "半句",
    "slug": "banju",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "banju",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#2C5F2D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.banju.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2C5F2D"
      },
      "package": "com.banju.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ]
  }
}
