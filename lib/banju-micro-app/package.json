{
  "name": "banju-micro-app",
  "version": "0.1.0",
  "private": true,
  "description": "半句 - 诗词小程序 (Taro 3)",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "sass"
  },
  "scripts": {
    "dev:weapp": "npm run build:weapp -- --watch",
    "dev:h5": "npm run build:h5 -- --watch",
    "build:weapp": "taro build --type weapp",
    "build:h5": "taro build --type h5",
    "build:alipay": "taro build --type alipay"
  },
  "dependencies": {
    "@banju/shared": "workspace:*",
    "@tarojs/components": "~4.0.0",
    "@tarojs/helper": "~4.0.0",
    "@tarojs/plugin-platform-weapp": "~4.0.0",
    "@tarojs/plugin-platform-h5": "~4.0.0",
    "@tarojs/react": "~4.0.0",
    "@tarojs/runtime": "~4.0.0",
    "@tarojs/shared": "~4.0.0",
    "@tarojs/taro": "~4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "@babel/preset-react": "^7.25.0",
    "@babel/preset-typescript": "^7.25.0",
    "@tarojs/cli": "~4.0.0",
    "@types/react": "^18.3.12",
    "babel-preset-taro": "~4.0.0",
    "sass": "^1.80.0",
    "@typescript/native-preview": "beta"
  }
}
